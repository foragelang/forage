{
    "name": "forage",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "packages/*",
        "hub-site/ide"
    ],
    "scripts": {
        "studio:dev": "cd apps/studio && cargo tauri dev",
        "studio:build": "bash scripts/run-studio.sh",
        "hub-ide:dev": "npm --prefix hub-site/ide run dev",
        "hub-site:dev": "npm --prefix hub-site run dev",
        "hub-site:build": "npm --prefix hub-site run build"
    }
}
